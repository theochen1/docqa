# docqa configuration — copy to `.env` and fill in. `.env` is git-ignored.
# Only the ANSWER path (docqa ask / eval) needs a key. Indexing is fully local + key-free.

# --- required for the answer path only ---
ANTHROPIC_API_KEY=

# --- models (all optional; defaults are fast + local-first) ---
# DOCQA_GEN_MODEL=claude-haiku-4-5-20251001   # fast tier; Opus blows the p50<5s budget
# DOCQA_EMBED_MODEL=BAAI/bge-small-en-v1.5     # local embedder; changing forces a reindex
# DOCQA_NLI_MODEL=cross-encoder/nli-deberta-v3-small

# --- retrieval knobs (tuned-not-universal; safe defaults) ---
# DOCQA_K=8
# DOCQA_RRF_K=60
# DOCQA_MMR_LAMBDA=0.5
# DOCQA_PER_SOURCE_CAP=2
# DOCQA_CLUSTER_SIM=0.80        # most likely to need per-corpus tuning

# --- verification thresholds ---
# DOCQA_ENTAIL_THRESHOLD=0.5
# DOCQA_CONFLICT_THRESHOLD=0.5
# DOCQA_OOS_FLOOR=0.30

# --- multi-hop (SHOULD, off by default) ---
# DOCQA_MULTIHOP=0
# DOCQA_MAX_HOPS=1
# DOCQA_HOP_DEADLINE_MS=2500

# --- generation ---
# DOCQA_TEMPERATURE=0.0
# DOCQA_SEED=0
# DOCQA_MAX_TOKENS=512

# --- paths ---
# DOCQA_INDEX_PATH=index.db
